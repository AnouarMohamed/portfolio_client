{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": [
    "server/**/*.ts",
    "src/cms/defaultBlogPosts.ts",
    "src/cms/defaultContent.ts",
    "src/cms/defaultProjects.ts",
    "src/cms/schema.ts",
    "src/cms/selectors.ts",
    "src/types.ts"
  ]
}
