# Admin credentials for the protected website editor.
ADMIN_USERNAME="client"

# Development fallback only. In production, use ADMIN_PASSWORD_HASH instead.
ADMIN_PASSWORD="change-me-now"

# Recommended and required in production.
# Generate with: npm run hash:password -- "your-strong-password"
ADMIN_PASSWORD_HASH=""

# Must be long and random. Use at least 32 characters.
SESSION_SECRET="replace-this-with-a-long-random-secret"

# Optional: move the client admin UI off the default /admin route.
# This is a build-time setting for the frontend.
VITE_ADMIN_PATH="/admin"

# Optional: allowed browser origins for authenticated admin write requests.
# Useful when the frontend and backend are not served from the same origin.
APP_ORIGIN=""
ALLOWED_ORIGINS=""

# Optional: restrict admin and auth endpoints to trusted client IPs only.
# Supports exact IPv4 addresses and IPv4 CIDR ranges, comma-separated.
ADMIN_ALLOWED_IPS=""

# Optional: enable trusted proxy IP forwarding when deployed behind a reverse proxy.
# Use true, false, or a hop count like 1.
TRUST_PROXY="false"

# Optional: tune login throttling and session lifetime.
ADMIN_LOGIN_WINDOW_MINUTES="15"
ADMIN_LOGIN_BLOCK_MINUTES="30"
ADMIN_LOGIN_MAX_ATTEMPTS="5"
ADMIN_SESSION_DAYS="7"
ADMIN_SESSION_IDLE_HOURS="12"

# Optional: override the CMS database location and server port.
CMS_DB_PATH="./data/cms.sqlite"
PORT="4000"

# Optional: set this when the frontend and backend run on different origins.
VITE_API_BASE_URL=""
